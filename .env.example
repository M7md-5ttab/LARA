# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lara
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
# Optional: use a socket instead of host/port
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# Public app base URL used in generated links
# Example: https://lara.example.com
APP_URL=

# Optional alias for the separate `telegram-bot` deployment.
# If you reuse this env file there, you can set either `LARA_APP_URL` or `APP_URL`.
LARA_APP_URL=

# Admin credentials for /admin/*
# IMPORTANT:
# - Put this file OUTSIDE your public web root in production.
# - Never commit your real `.env` (it's ignored by .gitignore).
ADMIN_USERNAME=admin

# Option A (recommended): bcrypt hash
# Generate via:
# php -r 'echo password_hash("YOUR_PASSWORD", PASSWORD_BCRYPT), PHP_EOL;'
ADMIN_PASSWORD_HASH=

# Option B: plain password (less secure; only use locally)
ADMIN_PASSWORD=

# Upload constraints
ADMIN_UPLOAD_MAX_BYTES=2097152

# Order checkout / notifications
# Required if customers should be redirected to WhatsApp after submitting an order.
# Example: 201508803316
WHATSAPP_ORDER_PHONE=

# Telegram bot / bridge
# Required if you use Telegram notifications or the standalone telegram bot.
# Set at least one of these token variables.
# Paste the raw token value only. Do not wrap it in quotes.
TELEGRAM_BOT_TOKEN=
TELEGRAM_TOKEN=

# Optional: override the Telegram webhook secret token.
# If left empty, the bot derives a stable secret from the bot token.
TELEGRAM_WEBHOOK_SECRET=

# Optional: force the webhook URL/origin if deployment auto-detection is wrong.
# Example: https://notify-admins.vercel.app/api
TELEGRAM_WEBHOOK_URL=

# Optional legacy alias for the webhook URL override.
BOT_WEBHOOK_URL=
