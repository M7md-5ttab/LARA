# Basic hardening for Apache.
# (Nginx / other servers need equivalent rules.)

<IfModule mod_authz_core.c>
  <FilesMatch "^\\.env">
    Require all denied
  </FilesMatch>

  <FilesMatch "\\.lock$">
    Require all denied
  </FilesMatch>
</IfModule>

RedirectMatch 404 /\\.git

<IfModule mod_headers.c>
  Header always setifempty X-Content-Type-Options "nosniff"
  Header always setifempty X-Frame-Options "DENY"
  Header always setifempty Referrer-Policy "no-referrer"

  SetEnvIf Query_String "(^|&)v=" HAS_ASSET_VERSION=1

  <FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|webp|svg|ico|woff2?|ttf)$">
    Header unset Pragma
    Header unset Expires
    Header set Cache-Control "public, max-age=3600, stale-while-revalidate=86400"
    Header set Cache-Control "public, max-age=31536000, immutable" env=HAS_ASSET_VERSION
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|webp|svg|ico|woff2?|ttf)$">
    ExpiresDefault "access plus 1 hour"
  </FilesMatch>
</IfModule>

